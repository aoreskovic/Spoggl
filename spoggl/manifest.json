{
  "id": "spoggl",
  "name": "Spoggl",
  "version": "0.3.0",
  "description": "Toggl-like daily time tracking with inline edit, pinned tasks, Jira worklog sync, and SP native timer integration.",
  "manifestVersion": 1,
  "minSupVersion": "14.0.2",
  "author": "Custom",
  "icon": "icon.svg",
  "iFrame": true,
  "sidePanel": false,
  "permissions": [
    "getTasks",
    "updateTask",
    "getAllProjects",
    "getAppState",
    "persistDataSynced",
    "loadSyncedData",
    "showSnack",
    "notify",
    "openDialog"
  ],
  "hooks": ["currentTaskChange", "action", "persistedDataChanged"]
}
